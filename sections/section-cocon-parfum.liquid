{% style %}
  #shopify-section-{{ section.id }} .cocon-section {
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .cocon-wrapper {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.side_padding }}px;
  }

  #shopify-section-{{ section.id }} .cocon-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.desktop_gap }}px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .cocon-grid.image-left .cocon-image-wrap {
    order: 1;
  }

  #shopify-section-{{ section.id }} .cocon-grid.image-left .cocon-content {
    order: 2;
  }

  #shopify-section-{{ section.id }} .cocon-grid.image-right .cocon-content {
    order: 1;
  }

  #shopify-section-{{ section.id }} .cocon-grid.image-right .cocon-image-wrap {
    order: 2;
  }

  #shopify-section-{{ section.id }} .cocon-content {
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .cocon-heading {
    margin: 0 0 {{ section.settings.title_margin_bottom }}px;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.15;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    font-family: inherit;
  }

  #shopify-section-{{ section.id }} .cocon-description {
    max-width: {{ section.settings.text_width }}px;
    margin-bottom: {{ section.settings.benefits_spacing }}px;
    font-size: {{ section.settings.text_size }}px;
    line-height: 1.8;
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .cocon-description p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .cocon-description strong {
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .cocon-benefits {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.benefit_gap }}px;
  }

  #shopify-section-{{ section.id }} .cocon-benefit {
    display: grid;
    grid-template-columns: {{ section.settings.icon_box_size }}px 1fr;
    gap: {{ section.settings.icon_text_gap }}px;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .cocon-icon {
    width: {{ section.settings.icon_box_size }}px;
    height: {{ section.settings.icon_box_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.icon_color }};
  }

  #shopify-section-{{ section.id }} .cocon-icon svg {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    stroke: currentColor;
  }

  #shopify-section-{{ section.id }} .cocon-icon img {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .cocon-benefit-title {
    margin: 0 0 6px;
    font-size: {{ section.settings.benefit_title_size }}px;
    line-height: 1.35;
    font-weight: 700;
    color: {{ section.settings.benefit_title_color }};
  }

  #shopify-section-{{ section.id }} .cocon-benefit-text {
    margin: 0;
    font-size: {{ section.settings.benefit_text_size }}px;
    line-height: 1.75;
    color: {{ section.settings.benefit_text_color }};
  }

  #shopify-section-{{ section.id }} .cocon-image-wrap {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .cocon-image-box {
    width: 100%;
    aspect-ratio: {{ section.settings.image_ratio }};
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    background: {{ section.settings.image_bg_color }};
  }

  #shopify-section-{{ section.id }} .cocon-image-box img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: {{ section.settings.image_fit }};
    object-position: center;
  }

  #shopify-section-{{ section.id }} .cocon-placeholder {
    width: 100%;
    height: 100%;
    background: #f4f0e8;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #777;
    font-size: 14px;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .cocon-grid {
      grid-template-columns: 1fr;
      gap: {{ section.settings.mobile_gap }}px;
    }

    #shopify-section-{{ section.id }} .cocon-grid.image-left .cocon-image-wrap,
    #shopify-section-{{ section.id }} .cocon-grid.image-right .cocon-image-wrap {
      order: {% if section.settings.mobile_image_first %}1{% else %}2{% endif %};
    }

    #shopify-section-{{ section.id }} .cocon-grid.image-left .cocon-content,
    #shopify-section-{{ section.id }} .cocon-grid.image-right .cocon-content {
      order: {% if section.settings.mobile_image_first %}2{% else %}1{% endif %};
    }

    #shopify-section-{{ section.id }} .cocon-heading {
      font-size: {{ section.settings.mobile_heading_size }}px;
    }

    #shopify-section-{{ section.id }} .cocon-description {
      font-size: {{ section.settings.mobile_text_size }}px;
      line-height: 1.75;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .cocon-benefit-title {
      font-size: {{ section.settings.mobile_benefit_title_size }}px;
    }

    #shopify-section-{{ section.id }} .cocon-benefit-text {
      font-size: {{ section.settings.mobile_benefit_text_size }}px;
    }

    #shopify-section-{{ section.id }} .cocon-section {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .cocon-wrapper {
      padding: 0 {{ section.settings.mobile_side_padding }}px;
    }

    #shopify-section-{{ section.id }} .cocon-benefit {
      grid-template-columns: {{ section.settings.mobile_icon_box_size }}px 1fr;
      gap: {{ section.settings.mobile_icon_text_gap }}px;
    }

    #shopify-section-{{ section.id }} .cocon-icon {
      width: {{ section.settings.mobile_icon_box_size }}px;
      height: {{ section.settings.mobile_icon_box_size }}px;
    }

    #shopify-section-{{ section.id }} .cocon-icon svg,
    #shopify-section-{{ section.id }} .cocon-icon img {
      width: {{ section.settings.mobile_icon_size }}px;
      height: {{ section.settings.mobile_icon_size }}px;
    }

    #shopify-section-{{ section.id }} .cocon-image-box {
      border-radius: {{ section.settings.mobile_image_radius }}px;
    }
  }
{% endstyle %}

<section class="cocon-section">
  <div class="cocon-wrapper">
    <div class="cocon-grid {{ section.settings.image_position }}">
      
      <div class="cocon-content">
        {% if section.settings.heading != blank %}
          <h2 class="cocon-heading">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="cocon-description">
            {{ section.settings.description }}
          </div>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="cocon-benefits">
            {% for block in section.blocks %}
              <div class="cocon-benefit" {{ block.shopify_attributes }}>
                
                <div class="cocon-icon">
                  {% if block.settings.icon_custom != blank %}
                    <img
                      src="{{ block.settings.icon_custom | image_url: width: 120 }}"
                      alt="{{ block.settings.title | escape }}"
                      loading="lazy"
                    >
                  {% else %}
                    {% case block.settings.icon %}
                      {% when 'france' %}
                        <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M25.5 5.5L33.5 8.5L38 6.5L42.5 13L50 15L49 23L54.5 30L49.5 36.5L52 45L43 47L39 57L30.5 52.5L22 56L18 47.5L9 45L13 36L8.5 29L14.5 23L14 14.5L21.5 12L25.5 5.5Z" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                          <path d="M49 52C51.5 50.5 55.5 50.7 56.5 54.5C57.1 56.8 55.5 58.5 53.5 58.5C51.5 58.5 50.3 57.2 50.2 55.5" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>

                      {% when 'bottle' %}
                        <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M27 7H37" stroke-width="1.8" stroke-linecap="round"/>
                          <path d="M29 7V18L24.5 25V56C24.5 58.2 26.3 60 28.5 60H35.5C37.7 60 39.5 58.2 39.5 56V25L35 18V7" stroke-width="1.8" stroke-linejoin="round"/>
                          <path d="M26 31H38" stroke-width="1.5" stroke-linecap="round"/>
                          <path d="M28.5 36H35.5" stroke-width="1.5" stroke-linecap="round"/>
                          <path d="M30 11H34" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>

                      {% when 'hands' %}
                        <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M6 33C13 29 20 28 27 32" stroke-width="1.6" stroke-linecap="round"/>
                          <path d="M5 41C15 37 24 38 32 43" stroke-width="1.6" stroke-linecap="round"/>
                          <path d="M58 28C48 30 40 34 34 41" stroke-width="1.6" stroke-linecap="round"/>
                          <path d="M57 39C49 41 42 45 37 51" stroke-width="1.6" stroke-linecap="round"/>
                          <path d="M20 23C24 22 28 23 31 25" stroke-width="1.4" stroke-linecap="round"/>
                          <path d="M39 22C35 24 31 27 28 31" stroke-width="1.4" stroke-linecap="round"/>
                        </svg>

                      {% else %}
                        <span></span>
                    {% endcase %}
                  {% endif %}
                </div>

                <div>
                  {% if block.settings.title != blank %}
                    <h3 class="cocon-benefit-title">
                      {{ block.settings.title }}
                    </h3>
                  {% endif %}

                  {% if block.settings.text != blank %}
                    <p class="cocon-benefit-text">
                      {{ block.settings.text }}
                    </p>
                  {% endif %}
                </div>

              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="cocon-image-wrap">
        <div class="cocon-image-box">
          {% if section.settings.image != blank %}
            <img
              src="{{ section.settings.image | image_url: width: 1400 }}"
              alt="{{ section.settings.image_alt | escape }}"
              loading="lazy"
            >
          {% else %}
            <div class="cocon-placeholder">
              Ajouter une image
            </div>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image + bénéfices cocon",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "L'art de parfumer votre Cocon"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Texte d’introduction",
      "default": "<p>Chez <strong>Olfazeta</strong>, nous apportons une touche de bien-être au quotidien. Nos parfums créent une atmosphère agréable, chaleureuse et confortable dans votre intérieur.</p>"
    },
    {
      "type": "range",
      "id": "text_width",
      "label": "Largeur du texte",
      "min": 300,
      "max": 900,
      "step": 20,
      "default": 620
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image principale"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texte alternatif image",
      "default": "Parfum d’intérieur"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Position image sur ordinateur",
      "default": "image-right",
      "options": [
        {
          "value": "image-right",
          "label": "Image à droite"
        },
        {
          "value": "image-left",
          "label": "Image à gauche"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "mobile_image_first",
      "label": "Afficher l’image en premier sur mobile",
      "default": true
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Format image",
      "default": "1 / 1",
      "options": [
        {
          "value": "1 / 1",
          "label": "Carré"
        },
        {
          "value": "4 / 3",
          "label": "4:3"
        },
        {
          "value": "16 / 9",
          "label": "16:9"
        },
        {
          "value": "3 / 4",
          "label": "Portrait"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Adaptation de l’image",
      "default": "cover",
      "options": [
        {
          "value": "cover",
          "label": "Remplir"
        },
        {
          "value": "contain",
          "label": "Contenir"
        }
      ]
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Arrondi image ordinateur",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 14
    },
    {
      "type": "range",
      "id": "mobile_image_radius",
      "label": "Arrondi image mobile",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 10
    },
    {
      "type": "color",
      "id": "image_bg_color",
      "label": "Fond image si contain",
      "default": "#f4f0e8"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond section",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Couleur titre",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur texte",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "benefit_title_color",
      "label": "Couleur titre bénéfice",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "benefit_text_color",
      "label": "Couleur texte bénéfice",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Couleur icônes",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Tailles typographie"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille titre ordinateur",
      "min": 20,
      "max": 70,
      "step": 1,
      "default": 30
    },
    {
      "type": "range",
      "id": "mobile_heading_size",
      "label": "Taille titre mobile",
      "min": 18,
      "max": 44,
      "step": 1,
      "default": 25
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Graisse titre",
      "default": "400",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ]
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Taille texte ordinateur",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "mobile_text_size",
      "label": "Taille texte mobile",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "benefit_title_size",
      "label": "Taille titre bénéfice ordinateur",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "mobile_benefit_title_size",
      "label": "Taille titre bénéfice mobile",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "benefit_text_size",
      "label": "Taille texte bénéfice ordinateur",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "mobile_benefit_text_size",
      "label": "Taille texte bénéfice mobile",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 16
    },
    {
      "type": "header",
      "content": "Espacements"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur maximum",
      "min": 900,
      "max": 1800,
      "step": 20,
      "default": 1320
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Padding côtés ordinateur",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_side_padding",
      "label": "Padding côtés mobile",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "desktop_gap",
      "label": "Espace entre texte et image ordinateur",
      "min": 20,
      "max": 160,
      "step": 5,
      "default": 80
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "label": "Espace entre image et texte mobile",
      "min": 10,
      "max": 80,
      "step": 2,
      "default": 32
    },
    {
      "type": "range",
      "id": "title_margin_bottom",
      "label": "Espace sous le titre",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "benefits_spacing",
      "label": "Espace avant les bénéfices",
      "min": 10,
      "max": 80,
      "step": 2,
      "default": 34
    },
    {
      "type": "range",
      "id": "benefit_gap",
      "label": "Espace entre les bénéfices",
      "min": 10,
      "max": 60,
      "step": 2,
      "default": 26
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Espace icône / texte ordinateur",
      "min": 6,
      "max": 40,
      "step": 1,
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_icon_text_gap",
      "label": "Espace icône / texte mobile",
      "min": 6,
      "max": 30,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding haut ordinateur",
      "min": 0,
      "max": 160,
      "step": 2,
      "default": 70
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bas ordinateur",
      "min": 0,
      "max": 160,
      "step": 2,
      "default": 70
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Padding haut mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Padding bas mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 40
    },
    {
      "type": "header",
      "content": "Icônes"
    },
    {
      "type": "range",
      "id": "icon_box_size",
      "label": "Largeur colonne icône ordinateur",
      "min": 24,
      "max": 80,
      "step": 2,
      "default": 42
    },
    {
      "type": "range",
      "id": "mobile_icon_box_size",
      "label": "Largeur colonne icône mobile",
      "min": 24,
      "max": 70,
      "step": 2,
      "default": 38
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Taille icône ordinateur",
      "min": 18,
      "max": 70,
      "step": 2,
      "default": 38
    },
    {
      "type": "range",
      "id": "mobile_icon_size",
      "label": "Taille icône mobile",
      "min": 18,
      "max": 60,
      "step": 2,
      "default": 34
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Bénéfice",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icône",
          "default": "france",
          "options": [
            {
              "value": "france",
              "label": "France"
            },
            {
              "value": "bottle",
              "label": "Flacon"
            },
            {
              "value": "hands",
              "label": "Mains"
            },
            {
              "value": "none",
              "label": "Aucune"
            }
          ]
        },
        {
          "type": "image_picker",
          "id": "icon_custom",
          "label": "Icône personnalisée PNG / SVG"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Fabrication Française"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texte",
          "default": "Tous nos parfums prennent vie en France, avec cœur, passion et conviction."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image + bénéfices cocon",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "france",
            "title": "Fabrication Française",
            "text": "Tous nos parfums prennent vie en France, avec cœur, passion et conviction."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "bottle",
            "title": "Artisanat",
            "text": "Chaque détail est soigné avec exigence, du geste de création jusqu’au parfum final."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "hands",
            "title": "Créations uniques et originales",
